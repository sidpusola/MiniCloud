# Copy to .env on each machine and adjust. Every value has a default;
# you only NEED to set the ones marked (required for multi-machine).

# ---- Control plane (machine that runs `python -m control_plane`) ----
MC_CP_HOST=0.0.0.0
MC_CP_PORT=8000
MC_CP_HEARTBEAT_INTERVAL_S=3
MC_CP_UNREACHABLE_AFTER_S=9
MC_CP_DEAD_AFTER_S=20
MC_CP_RECONCILE_INTERVAL_S=4
# Delay before scheduling NEW replicas at startup, so surviving workers can
# re-report and have their containers adopted (prevents restart duplicates):
MC_CP_STARTUP_GRACE_S=12
# Where desired state (deployments) is persisted. SQLite file by default;
# for Postgres: postgresql+psycopg://user:pw@host:5432/mini_cloud
MC_CP_DATABASE_URL=sqlite:///mini_cloud.db

# ---- Worker agent (each worker machine runs `python -m worker`) ----
# (required for multi-machine) URL of the control plane, reachable from here:
MC_WORKER_CONTROL_PLANE_URL=http://CONTROL_PLANE_IP:8000
MC_WORKER_HOST=0.0.0.0
MC_WORKER_PORT=8001
# (required for multi-machine) this worker's IP as seen by the control plane
# and proxy. Published container ports are reached at this address.
MC_WORKER_ADVERTISE_HOST=THIS_WORKER_LAN_IP
MC_WORKER_ADVERTISE_PORT=8001
# Optional stable id (defaults to node-<hostname>):
# MC_WORKER_NODE_ID=worker-1

# ---- Reverse proxy (machine that runs `python -m proxy`) ----
MC_PROXY_HOST=0.0.0.0
MC_PROXY_PORT=8080
MC_PROXY_CONTROL_PLANE_URL=http://CONTROL_PLANE_IP:8000
MC_PROXY_REFRESH_INTERVAL_S=3
